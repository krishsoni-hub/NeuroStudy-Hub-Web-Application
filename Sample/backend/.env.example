# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/neurostudyhub

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── OpenRouter AI (FREE) ─────────────────────────────────────────────────────
# Sign up free at https://openrouter.ai → Dashboard → API Keys → Create Key
# Free tier: no credit card required, generous limits
OPENROUTER_API_KEY=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

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail"
# 4. Paste the 16-character password below (no spaces)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=abcd efgh ijkl mnop
EMAIL_FROM="NeuroStudy Hub <your_gmail@gmail.com>"

# ─── Frontend URL (used in email links) ───────────────────────────────────────
# If using VS Code Live Server the default is 5500
# If opening files directly use: file:///path/to/Sample
FRONTEND_URL=http://localhost:5500
